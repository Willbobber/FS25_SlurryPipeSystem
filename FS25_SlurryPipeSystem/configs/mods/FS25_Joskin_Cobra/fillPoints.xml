<?xml version="1.0" encoding="utf-8"?>
<!-- FS25 Joskin Cobra -->

<!-- FS25_SlurryPipeSystem — Vehicle fillPoints.xml -->
<!-- Author: Oscar Mods -->
<!-- Version: 1.0.0.0 -->

<slurryPipeSystem>
    <nodeTree filename="nodeTree.i3d"/>

    <flow fillLitersPerSecond="300" emptyLitersPerSecond="900"/>
	
	<spreaderAnimation name="sprayerAnimation1" stopDelay="1.5"/>
	
	<pump pumpType="vacuum"/>     <!-- vacuum/HVP/conduit/openTop -->
	
	<!-- Pressure section optional. Omit entirely to use the SPS defaults shown below.
		maxPressure     : ±bar ceiling; HUD reads from -this to +this
		minThreshold    : bar of stored pressure needed before flow can start
		minBuildTime    : seconds to reach max at a FULL tank (fast build)
		maxBuildTime    : seconds to reach max at an EMPTY tank (slow build); scales by fill ratio
		fallTimeWorking : seconds max->0 while fluid is still transferring (slow taper)
		fallTimeEmpty   : seconds max->0 while venting with no transfer (faster)
		purgeTime       : seconds to vent max->0 when flipping direction against stored pressure
		openTop         : true = passive open-top vessel (FRC-style), never holds pressure, no gauge -->
	<pressure
		maxPressure="2.0"
		minThreshold="0.3"
		minBuildTime="10"
		maxBuildTime="30"
		fallTimeWorking="30"
		fallTimeEmpty="60"
		purgeTime="10"
		openTop="false"
	/>
	
    <fillArms>

        <fillArm
            id="1"
            cylinderedConfigIndex="0"
			configType="design4"
            tipType="OPEN_PIT"
            centreNodeName="SPS_fillArmCentre01"
            fillUnitIndex="1"
		>	
			<effects>
                <effectNode effectClass="PipeEffect" effectNode="effect" materialType="pipe"
                            maxBending="0.8" extraDistance="0.1" positionUpdateNodes="pipeEffectSmoke"/>
                <effectNode effectNode="pipeEffectSmoke" materialType="unloadingSmoke"
                            delay="0.1" alignToWorldY="true"/>
            </effects>
		</fillArm>

        <fillArm
            id="2"
            cylinderedConfigIndex="1"
			configType="design4"
            tipType="RUBBER_BOOT"
            tipNodeName="SPS_fillArmTip01"
            fillUnitIndex="1"
        />

    </fillArms>

    <pipeCouplings>

        <pipeCoupling
            id="1"
            mountNodeName="SPS_pipeCoupler01"
            valveType="MANUAL"
            maxPipeLength="4.0"
            fillUnitIndex="1"
            valveFromRearControl="false"
			connector="male"
        />

        <pipeCoupling
            id="2"
            mountNodeName="SPS_pipeCoupler02"
            valveType="MANUAL"
            maxPipeLength="4.0"
            fillUnitIndex="1"
            valveFromRearControl="false"
			connector="male"
        />

    </pipeCouplings>

    <rubberBootPorts/>

    <outsideControls>
		<outsideControl mountNodeName="pumpControl01" pto="true" direction="false"/>
	</outsideControls>
	
	<blockageNodes>
        <blockageNode workAreaConfigIndex="0" mountNodeName="SPS_blockageNodeSplashPlate" workAreaNode="workArea01" blockageAnimation="splashPlate"/>
		<blockageNode workAreaConfigIndex="1" mountNodeName="SPS_blockageNodeSplashPlate" workAreaNode="workArea02" blockageAnimation="splashPlate"/>
	</blockageNodes>
	
	<sounds fullThreshold="0.99">
		<vacPumpFilling template="slurry01"/>
		<vacPumpFull    template="slurry02"/>
	</sounds>
	
</slurryPipeSystem>