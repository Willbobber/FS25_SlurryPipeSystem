<sprayerPipeSystem>

    <nodeTree filename="nodeTree.i3d"/>

    <flow litersPerSecond="200"/>
	
	<pump selfPowered="true"/>
	
    <sounds>
        <engineLoop
            file="$data/vehicles/agi/utx44/sounds/utx44_loop.gls"
            linkNode="exhaustNode"
            innerRadius="10"
            outerRadius="80"
        />
    </sounds>
	
    <sprayerPipeCouplings>

        <sprayerPipeCoupling
            id="1"
            mountNodeName="SPS_sprayerPipeCoupler01"
			flowDirection="BOTH"
            pipeType="sprayerPipe"
			maxPipeLength="7.5"
            fillUnitIndex="1"
            valveFromRearControl="true"
			connectorAnimation="3"
            valveAnimation="1"
		/>

    </sprayerPipeCouplings>

    <sprayerPumpControls>
        <sprayerPumpControl
            id="1"
            nodeName="sprayerControlNode"
            radius="1.5"
        />

    </sprayerPumpControls>
	
</sprayerPipeSystem>