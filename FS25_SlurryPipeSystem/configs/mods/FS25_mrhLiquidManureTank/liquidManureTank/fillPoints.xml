<!-- FS25_SlurryPipeSystem — Placeable fillPoints.xml -->
<!-- Author: Oscar Mods -->
<!-- Version: 1.0.0.0 -->

<slurryPipeSystem agitator="true">
 
    <nodeTree filename="nodeTree.i3d"/>
	
    <fillPlane
        node="liquidManurePlane"
        minY="0.09"
        maxY="6.4"
        fillType="LIQUIDMANURE"
		shape="round"
        centreNodeName="slurryPlaneCentre"
        edgeNodeName="slurryPlaneEdge"
    />
 
    <pipeCouplings>
 
        <pipeCoupling
            id="1"
            mountNodeName="SPS_pipeCoupler01"
            flowDirection="DISCHARGE"
            valveType="MANUAL"
			deployable="false"
            maxPipeLength="4.0"
			connector="male"
			connectorAnimation="1"
			valveAnimation="2"
        >
            <effects inletDistance="10.0">
                <effectNode effectClass="PipeEffect" effectNode="effect" materialType="pipe"
                            maxBending="0.8" extraDistance="0.1" positionUpdateNodes="pipeEffectSmoke"/>
                <effectNode effectNode="pipeEffectSmoke" materialType="unloadingSmoke"
                            startDelay="0.1" alignToWorldY="true"/>
            </effects>
        </pipeCoupling>
 
        <pipeCoupling
            id="2"
            mountNodeName="SPS_pipeCoupler02"
            flowDirection="BOTH"
            valveType="MANUAL"
			deployable="false"
            maxPipeLength="4.0"
			connector="male"
			connectorAnimation="1"
			valveAnimation="2"
        />
 
    </pipeCouplings>
 
    <hideNodes>
        <node name="fillTowerNode"/>
        <node name="fillTowerPipe"/>
        <node name="fillTowerPipe_boltDecals"/>
    </hideNodes>
 
    <hideCollisions>
        <node name="fillTowerPipe_collisions"/>
        <node name="tipCollisions_fillTower"/>
        <node name="collisionFillTower"/>
    </hideCollisions>
	
	<fixedAgitator turnOffIfNotAllowed="true">
		<input inputNode="ptoNodeAttached" detachNode="ptoNodeDetached" filename="$data/shared/assets/powerTakeOffs/walterscheidW.xml" materialTemplateName="SHARED_BLACK1" decalMaterialTemplateName="WALTERSCHEID_YELLOW1"/>
		<level node="agitatorLevelNode "/>
		<animationNodes>
            <animationNode node="blades" rotSpeed="1000" rotAxis="1" turnOnFadeTime="2" turnOffFadeTime="8" />
        </animationNodes>
		<sounds>
			<turnedOn template="tractorPTO" volumeScale="0.7" linkNode="soundNode"/>
		</sounds>
	</fixedAgitator>
	
	<crust density="0.3">
		<plant stage="1" i3d="i3d/foliage/grass01.i3d"  weight="6"/>
		<plant stage="2" i3d="i3d/foliage/grass02.i3d"  weight="5"/>
		<plant stage="3" i3d="i3d/foliage/grass03.i3d"  weight="5"/>
		<plant stage="2" i3d="i3d/foliage/barley01.i3d" weight="4"/>
		<plant stage="3" i3d="i3d/foliage/barley02.i3d" weight="4"/>
		<plant stage="3" i3d="i3d/foliage/barley03.i3d" weight="3"/>
		<plant stage="3" i3d="i3d/foliage/barley04.i3d" weight="3"/>
		<plant stage="3" i3d="i3d/foliage/mushroom.i3d" weight="3"/>
		<plant stage="3" i3d="i3d/foliage/nettle.i3d"   weight="3"/>
	</crust>
	
</slurryPipeSystem>

