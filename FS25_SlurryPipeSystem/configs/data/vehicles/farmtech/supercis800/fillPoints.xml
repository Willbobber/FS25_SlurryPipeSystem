<?xml version="1.0" encoding="utf-8"?>
<!-- Farmtech Supercis 800 -->

<!-- FS25_SlurryPipeSystem — Vehicle fillPoints.xml -->
<!-- Author: Oscar Mods -->
<!-- Version: 1.0.0.0 -->

<slurryPipeSystem>

    <nodeTree filename="nodeTree.i3d"/>

    <flow fillLitersPerSecond="410" emptyLitersPerSecond="410"/>
	
	<pump pumpType="vacuum"/>     <!-- vacuum/HVP/conduit/openTop -->
	
	<spreaderAnimation name="sprayerAnimation" stopDelay="1.5"/>
	
	<shearBolt bolt="true"/>
	
	<!-- Pressure section optional. Omit entirely to use the SPS defaults shown below.
		maxPressure     : ±bar ceiling; HUD reads from -this to +this
		minThreshold    : bar of stored pressure needed before flow can start
		minBuildTime    : seconds to reach max at a FULL tank (fast build)
		maxBuildTime    : seconds to reach max at an EMPTY tank (slow build); scales by fill ratio
		fallTimeWorking : seconds max->0 while fluid is still transferring (slow taper)
		fallTimeEmpty   : seconds max->0 while venting with no transfer (faster)
		purgeTime       : seconds to vent max->0 when flipping direction against stored pressure
		openTop         : true = passive open-top vessel (FRC-style), never holds pressure, no gauge -->
	<pressure
		maxPressure="2.0"
		minThreshold="0.3"
		minBuildTime="10"
		maxBuildTime="30"
		fallTimeWorking="30"
		fallTimeEmpty="60"
		purgeTime="10"
		openTop="false"
	/>
	
    <pipeCouplings>

        <pipeCoupling
            id="1"
            mountNodeName="SPS_pipeCoupler01"
            valveType="MANUAL"
            maxPipeLength="4.0"
            fillUnitIndex="1"
            valveFromRearControl="false"
			connector="male"
        />

    </pipeCouplings>

    <rubberBootPorts/>

    <outsideControls>
		<outsideControl mountNodeName="pumpControl01" pto="true" direction="true"/>
	</outsideControls>
	
	<blockageNodes>
        <blockageNode mountNodeName="SPS_blockageNodeSplashPlate" workAreaNode="workArea01" blockageAnimation="splashPlate"/>
	</blockageNodes>
	
	<sounds fullThreshold="0.99">
		<vacPumpFilling template="slurry01"/>
		<vacPumpFull    template="slurry02"/>
	</sounds>

</slurryPipeSystem>