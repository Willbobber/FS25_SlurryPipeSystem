<!-- FS25_SlurryPipeSystem — Vehicle fillPoints.xml -->
<!-- Author: Oscar Mods -->
<!-- Version: 1.0.0.0 -->

<slurryPipeSystem>

    <nodeTree filename="nodeTree.i3d"/>

    <flow fillLitersPerSecond="1500" emptyLitersPerSecond="1500"/>
	
	<pump pumpType="vacuum" selfPowered="true"/>     <!-- vacuum/HVP/conduit/openTop -->
	
	<surfaceRef emptyNode="emptyNode" fullNode="fullNode"/>
	
	<!-- Pressure section optional. Omit entirely to use the SPS defaults shown below.
		maxPressure     : ±bar ceiling; HUD reads from -this to +this
		minThreshold    : bar of stored pressure needed before flow can start
		minBuildTime    : seconds to reach max at a FULL tank (fast build)
		maxBuildTime    : seconds to reach max at an EMPTY tank (slow build); scales by fill ratio
		fallTimeWorking : seconds max->0 while fluid is still transferring (slow taper)
		fallTimeEmpty   : seconds max->0 while venting with no transfer (faster)
		purgeTime       : seconds to vent max->0 when flipping direction against stored pressure
		openTop         : true = passive open-top vessel (FRC-style), never holds pressure, no gauge -->
	<pressure
		maxPressure="2.0"
		minThreshold="0.3"
		minBuildTime="10"
		maxBuildTime="30"
		fallTimeWorking="30"
		fallTimeEmpty="60"
		purgeTime="10"
		openTop="false"
	/>
	
    <sounds>
        <engineLoop
            file="$data/vehicles/agi/utx44/sounds/utx44_loop.gls"
            linkNode="exhaustNode"
            innerRadius="10"
            outerRadius="80"
        />
    </sounds>

    <fillArms/>

    <pipeCouplings>

        <pipeCoupling
            id="1"
            mountNodeName="SPS_pipeCoupler01"
            valveType="NONE"
            maxPipeLength="4.0"
            fillUnitIndex="1"
            valveFromRearControl="true"
			connector="male"
        />

    </pipeCouplings>

    <rubberBootPorts>

        <rubberBootPort
            id="1"
            lowerNodeName="SPS_rubberBootLower01"
            upperNodeName="SPS_rubberBootUpper01"
            valveType="NONE"
            fillUnitIndex="1"
        />

    </rubberBootPorts>

    <pumpControls>

        <pumpControl
            id="1"
            nodeName="rearControlNode"
            radius="1.5"
        />

    </pumpControls>

</slurryPipeSystem>
