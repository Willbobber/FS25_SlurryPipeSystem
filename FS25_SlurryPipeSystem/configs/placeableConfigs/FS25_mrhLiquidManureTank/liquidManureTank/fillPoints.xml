<?xml version="1.0" encoding="utf-8"?>
<!--
    FS25_SlurryPipeSystem
    placeableConfigs/FS25_mrhLiquidManureTank/fillPoints.xml

    FS25_mrhLiquidManureTank - liquid manure tower tank

    nodeTree links SPS_pipeCoupler01 and SPS_pipeCoupler02 onto the
    placeable hierarchy. The container name in the nodeTree must match
    a node name that exists in the placeable's component hierarchy.

    Fill plane:
        node:   liquidManurePlane  (i3dMapping 0>4|1|0 in liquidManureTank.xml)
        minY:   0.09  (surface Y when empty)
        maxY:   6.4   (surface Y when full, capacity 1500000L)
        fillType: LIQUIDMANURE
-->
<slurryPipeSystem>

    <nodeTree filename="nodeTree.i3d"/>

    <fillPlane
        node="liquidManurePlane"
        minY="0.09"
        maxY="6.4"
        fillType="LIQUIDMANURE"
    />

    <pipeCouplings>
        <pipeCoupling
            id="1"
            mountNodeName="SPS_pipeCoupler01"
            fillUnitIndex="1"
            valveType="MANUAL"
            gravity="false"
            maxPipeLength="4.0"
        />
        <pipeCoupling
            id="2"
            mountNodeName="SPS_pipeCoupler02"
            fillUnitIndex="1"
            valveType="MANUAL"
            gravity="true"
            maxPipeLength="4.0"
        />
    </pipeCouplings>

</slurryPipeSystem>