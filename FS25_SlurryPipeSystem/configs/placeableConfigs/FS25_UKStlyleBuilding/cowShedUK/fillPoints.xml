<?xml version="1.0" encoding="utf-8"?>
<!--
    FS25_SlurryPipeSystem
    placeableConfigs/FS25_UKStyleBuilding/fillPoints.xml

    cowShedUK + cowShedUK_nonMilk (cowHusbandryMilkCows)
    Both variants match this config via substring — "cowShedUK" is found
    inside "cowShedUK_nonMilk".

    From cowShedUK.xml:
        fillPlane node:     "manurePlane_milk"  (i3dMapping 0>16|2)
            fillType:       LIQUIDMANURE
            minY:          -1.94  (local Y when storage empty)
            maxY:           0.0   (local Y when storage full)
        loadingTrigger:     "loadingTrigger_milk"
            AABB box used by vanilla slurryTank fill system.
            Reused for fill arm upper-node bounding box detection.
-->
<slurryPipeSystem>

	<nodeTree filename="nodeTree.i3d"/>
	
	<pipeAnimNode node="slurryGridA09" rx="-13" ry="0" rz="0"/>
	
    <fillPlane
        node="manurePlane_milk"
        minY="-1.94"
        maxY="0.0"
        fillType="LIQUIDMANURE"
        triggerNode="liquidManureTrigger_milk"
    />
	
	<pipeCouplings>
        <pipeCoupling
            id="1"
            mountNodeName="SPS_pipeCoupler01"
            fillUnitIndex="1"
            valveType="NONE"
            gravity="true"
			deployable="true"
            maxPipeLength="4.0"
        />
    </pipeCouplings>
</slurryPipeSystem>
