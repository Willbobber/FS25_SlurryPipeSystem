<?xml version="1.0" encoding="utf-8"?>
<!--
    FS25_SlurryPipeSystem
    placeableConfigs/baseTank/fillPoints.xml

    Brandless Liquid Manure Tank (baseTank) - placeable silo type

    From baseTank.xml:
        storage node:       "storage"          (i3dMapping 0>3|0)
        fillPlane node:     "slurryPit_fillPlane" (i3dMapping 0>3|0|0)
            fillType:       LIQUIDMANURE
            minY:           0       (local Y when storage empty)
            maxY:           0.763   (local Y when storage full, capacity=500000L)
        loadingTrigger:     "loadingTrigger"   (i3dMapping 0>3|1|0|0)
            Reused as bounding box for fill arm upper-node detection.

    Fill plane surface Y detection:
        getSurfaceWorldY reads getWorldTranslation(slurryPit_fillPlane) Y directly.
-->
<slurryPipeSystem>

    <fillPlane
        node="slurryPit_fillPlane"
        minY="0"
        maxY="0.763"
        fillType="LIQUIDMANURE"
        triggerNode="loadingTrigger"
    />

</slurryPipeSystem>