<?xml version="1.0" encoding="utf-8" standalone="no"?>
<modDesc descVersion="107">

    <author>Oscar Mods</author>
    <version>1.0.0.0</version>
    <title>
        <en>Slurry Pipe System</en>
    </title>
    <description>
        <en>Replaces the vanilla drive-in-and-press-button slurry filling with a realistic
pipe and fill arm system. Tankers must connect hydraulic fill arms into the slurry
or physically connect pipes before flow can start. Pump must be on. Flow
direction is selectable. Supports open pit arms, receiver cup tanker-to-tanker
transfer, slurry pipes, and nurse tank operation.</en>
    </description>
    <iconFilename>icon_slurryPipeSystem.dds</iconFilename>

    <slurryPipeSystem debug="false" />

    <l10n filenamePrefix="l10n/l10n" />
	
	<extraSourceFiles>
        <sourceFile filename="scripts/util/SlurryDebug.lua" />
        <sourceFile filename="scripts/util/SlurryNodeUtil.lua" />
        <sourceFile filename="scripts/util/SPSEvents.lua" />
		<sourceFile filename="scripts/util/SPSPipeVisual.lua"/>
		<sourceFile filename="scripts/util/SPSPipeActivatable.lua"/>
		<sourceFile filename="scripts/util/SPSPipeChain.lua"/>
		<sourceFile filename="scripts/util/SPSChainActivatable.lua"/>
		
        <sourceFile filename="scripts/manager/SlurryPipeManager.lua" />

        <sourceFile filename="scripts/overrides/ManureBarrelOverride.lua" />

        <sourceFile filename="scripts/init.lua" />
		
	</extraSourceFiles>

    <connectionHoses filename="connectionHoses/slurryPipe.xml"/>
	
	<actions>
		<action name="SPS_TOGGLE_PUMP"      axisType="HALF" category="VEHICLE" />
		<action name="SPS_TOGGLE_FLOW"      axisType="HALF" category="VEHICLE" />
		<action name="SPS_TOGGLE_DIRECTION" axisType="HALF" category="VEHICLE" />
	</actions>
	
	<inputBinding>
		<actionBinding action="SPS_TOGGLE_PUMP">
			<binding device="KB_MOUSE_DEFAULT" input="KEY_b" axisComponent="+" index="1" />
		</actionBinding>
		<actionBinding action="SPS_TOGGLE_FLOW">
			<binding device="KB_MOUSE_DEFAULT" input="KEY_x" axisComponent="+" index="1" />
		</actionBinding>
		<actionBinding action="SPS_TOGGLE_DIRECTION">
			<binding device="KB_MOUSE_DEFAULT" input="KEY_y" axisComponent="+" index="1" />
		</actionBinding>
	</inputBinding>
</modDesc>
